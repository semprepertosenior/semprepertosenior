                        <a href="https://wa.me/5512991845196?text=Gostaria%20de%20saber%20mais%20sobre%20o%20acompanhamento%20em%20consultas%20m%C3%A9dicas." 
                           target="_blank" 
                           class="bg-white border-4 border-deep-black text-deep-black text-center px-8 py-5 text-lg font-bold uppercase tracking-wider hover:bg-gray-100 transition-all duration-300 inline-flex items-center justify-center gap-2">
                            <i class="fa-brands fa-whatsapp text-2xl text-emerald-700"></i> Agendar Acompanhamento
                        </a>
                    </div>
                </div>
                <div class="lg:col-span-5">
                    <div class="bg-white border-4 border-deep-black p-8 text-center space-y-6 shadow-xl">
